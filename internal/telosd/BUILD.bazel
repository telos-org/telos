load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "telosd",
    srcs = [
        "config.go",
        "server.go",
        "worker.go",
    ],
    importpath = "github.com/telos-org/telos-go/internal/telosd",
    visibility = ["//:__subpackages__"],
    deps = [
        "//internal/cli",
